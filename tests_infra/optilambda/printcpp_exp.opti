  fun one_fork(): unit {
    letmut x = 0;
    let fork_out: __ghost_fn = __ghost_begin(ghost(ro_fork_group()[H := ~>(x, CellOf(Any)(0)), r := range(0, 5, 1)]));
    for<seq> i in 0..5 [#275, #274, #274] {
      strict;
      requires #275: _Fraction;
      xconsumes #274: _RO(#275, ~>(x, CellOf(Any)(0)));
      xproduces #274: _RO(#275, ~>(x, CellOf(Any)(0)));
      ghost(ro_split2()[f := #_1, H := ~>(x, CellOf(Any)(0))]);
      ghost(ro_fork_group()[f := #_1 / 2, H := ~>(x, CellOf(Any)(0)), r := range(0, 5, 1)]);
      ghost(ro_allow_join2()[f := #_1, H := ~>(x, CellOf(Any)(0))]);
      for<seq> j in 0..5 [#277, #276, #276] {
        strict;
        requires #277: _Fraction;
        xconsumes #276: _RO(#277, ~>(x, CellOf(Any)(0)));
        xproduces #276: _RO(#277, ~>(x, CellOf(Any)(0)));
        __ignore(x + 1);
      };
      ghost(ro_join_group()[H := ~>(x, CellOf(Any)(0)), r := range(0, 5, 1)]);
    };
    __ghost_end(fork_out);
  };
